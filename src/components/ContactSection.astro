---
import { getImage } from "astro:assets";
import patronLogo from "@assets/svg/PatronLogo.svg";

const optimazatedPattern = await getImage({ src: patronLogo });
---

<section class="container bg-[#f2f2f4] text-background px-4 py-14 md:grid md:grid-cols-[1.4fr_1fr] md:py-20">
  <article class="max-w-3xl py-2 md:pr-12">
    <h2 class="text-3xl font-semibold md:text-4xl">Contacto</h2>

    <p class="mt-5 text-lg leading-relaxed md:text-2xl md:leading-[1.35]">
      Si quieres conocer más sobre Monarca Camellia o colaborar con nosotras,
      ¡contáctanos!
    </p>

    <ul class="mt-8 space-y-5 text-lg md:text-2xl">
      <li class="flex items-center gap-4 md:gap-5">
        <svg
          width="37"
          height="38"
          viewBox="0 0 37 38"
          fill="none"
          class="size-7 text-secondary md:size-8"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
