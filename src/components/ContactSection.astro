            fill="currentColor"
          ></path>
        </svg>
        <a class="hover:underline" href="mailto:atencion@monarcacamellia.com"
          >atencion@monarcacamellia.com</a
        >
      </li>
    </ul>

    <div class="mt-10 space-y-3 text-lg leading-relaxed md:text-2xl">
      <h3 class="font-semibold">Atención personalizada</h3>
      <p><strong>Kerstin Wittig</strong> - kwittig@monarcacamellia.com</p>
      <p><strong>Maricela Rivera</strong> - maricela.rivera@monarcacamellia.com</p>
    </div>
  </article>

  <div class="contact-pattern mt-10 min-h-72 md:mt-0" aria-hidden="true"></div>
</section>

<style define:vars={{ patternUrl: `url(${optimazatedPattern.src})` }}>
  .contact-pattern {
    background-image: var(--patternUrl);
    background-repeat: repeat;
    background-size: 11rem;
    background-position: center;
  }
</style>
