            fill="currentColor"
          ></path>
        </svg>
        <a
          class="hover:underline"
          href="https://wa.me/525579868490"
          target="_blank"
          rel="noopener noreferrer">+525579868490</a
        >
      </li>

      <li class="flex items-center gap-4 md:gap-5">
        <svg
          width="37"
          height="29"
          viewBox="0 0 37 29"
          fill="none"
          class="size-7 text-primary md:size-8"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
